# Fenice bRain — Variáveis de Ambiente
# Copie para .env e preencha (não commitar o .env real)

# ── Supabase REST API (pipeline Planalto → legislacao_brasileira) ─────────────
# Não requer senha do banco — apenas a service_role key
# Dashboard: Settings → Chaves de API → service_role → Revelar
SUPABASE_URL=https://qcfdssnpjzvjbvemhrik.supabase.co
SUPABASE_SERVICE_KEY=SUA_SERVICE_ROLE_KEY_AQUI

# ── RAG Semântico — síntese LLM (escolha um) ────────────────────────────────
# Dev/teste (GRATUITO): console.groq.com → API Keys
GROQ_API_KEY=SUA_GROQ_API_KEY_AQUI
# Produção (pago por token): console.anthropic.com → API Keys
# ANTHROPIC_API_KEY=SUA_ANTHROPIC_API_KEY_AQUI

# ── Site — autenticação (modal de login) ─────────────────────────────────────
# Credenciais do modal de entrada no site
SITE_USER=admin
SITE_PASS=ESCOLHA_UMA_SENHA_FORTE_AQUI
SITE_SECRET=GERE_UMA_STRING_ALEATORIA_LONGA_AQUI

# ── Referência rápida ──────────────────────────────────────────────────────────
