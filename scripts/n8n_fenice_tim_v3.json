    {
      "parameters": {
        "jsCode": "// ── Decide o próximo passo com base no perfil do contato ──────────\nconst dadosMsg = $('2. Extrair e Normalizar').first().json;\nconst contatosArr = ($input.first().json.contatos) || [];\nconst contato = contatosArr.length > 0 ? contatosArr[0] : null;\n\nconst areaAtual = contato ? contato.area : null;\nconst { isReset, opcaoMenu, numero, nome, mensagem } = dadosMsg;\n\n// Reset explícito ou contact quer voltar ao menu\nif (isReset) {\n  return [{ json: { _acao: 'menu_principal', numero, nome, mensagem, areaAtual: null } }];\n}\n\n// Contato novo (sem área) ou opção inválida → menu principal\nif (!areaAtual && !opcaoMenu) {\n  return [{ json: { _acao: 'menu_principal', numero, nome, mensagem, areaAtual: null } }];\n}\n\n// Contato sem área + escolheu opção válida → salva área e responde\nif (!areaAtual && opcaoMenu) {\n  if (opcaoMenu === 'humano') {\n    return [{ json: { _acao: 'humano', numero, nome, mensagem, areaAtual: 'humano' } }];\n  }\n  return [{ json: { _acao: 'set_area', numero, nome, mensagem, areaAtual: opcaoMenu } }];\n}\n\n// Contato com área definida → responde na área\nreturn [{ json: { _acao: 'responder', numero, nome, mensagem, areaAtual } }];"
      },
