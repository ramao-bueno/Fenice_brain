      "parameters": {
        "jsCode": "// ── Extrai e normaliza — suporta AvisaAPI real (jsonData) e curl flat ──\nconst raw = $input.first().json;\nconst body = raw?.body || raw;\nlet jsonData = body?.jsonData || {};\nif (typeof jsonData === 'string') { try { jsonData = JSON.parse(jsonData); } catch(e) { jsonData = {}; } }\nconst info = jsonData?.event?.Info || {};\nconst msg  = jsonData?.event?.Message || {};\n\nif (info?.IsFromMe) return [{ json: { _skip: true, motivo: \"fromMe\" } }];\nif (info?.IsGroup)  return [{ json: { _skip: true, motivo: \"grupo\" } }];\n\nconst chatJid    = info?.Chat || info?.Sender || \"\";\nconst flatNumero = body?.number || body?.from || body?.phone || \"\";\nconst numero     = (chatJid.split(\"@\")[0] || flatNumero).replace(/[^0-9]/g, \"\");\n\nconst flatMsg  = (typeof body?.message === \"string\" ? body.message : \"\") || body?.text || body?.content || \"\";\nconst mensagem = (msg?.conversation || msg?.extendedTextMessage?.text || msg?.imageMessage?.caption || flatMsg).trim();\n\nconst nome      = info?.PushName || body?.name || body?.pushName || \"Cliente\";\nconst messageId = info?.ID       || body?.id   || \"\";\nconst sessionId = info?.Chat     || body?.chatId || body?.session || \"\";\n\nif (!numero || !mensagem) return [{ json: { _skip: true, motivo: \"sem numero ou mensagem\" } }];\n\nconst msgLower    = mensagem.toLowerCase().replace(/[!.?]+$/, \"\").trim();\nconst STOP_WORDS  = [\"parar\",\"stop\",\"sair\",\"cancelar\"];\nconst RESET_WORDS = [\"menu\",\"inicio\",\"início\",\"voltar\",\"reiniciar\"];\nconst MENU_OPCOES = {\"1\":\"b2b\",\"2\":\"academico\",\"3\":\"observatorio\",\"4\":\"api\",\"5\":\"juridico\",\"6\":\"filosofia\",\"0\":\"humano\"};\n\nreturn [{ json: { _skip: false, numero, nome, mensagem, msgLower, sessionId, messageId,\n  isStop: STOP_WORDS.includes(msgLower), isReset: RESET_WORDS.includes(msgLower),\n  opcaoMenu: MENU_OPCOES[msgLower] || null } }];"
      },
