        "jsCode": "const avisaResult = $input.first().json;\nconst dadosMsg = $('12. Extrair Resposta Groq').first().json;\n\nconst entregue = avisaResult.status === true;\nconst httpStatus = avisaResult.data?.response?.code || 200;\n\nconst logBody = JSON.stringify({\n  numero_remetente: dadosMsg.numero,\n  nome_remetente: dadosMsg.nome,\n  mensagem_cliente: dadosMsg.mensagem,\n  resposta_ai: dadosMsg.respostaAi,\n  modelo_ai: dadosMsg.modeloAi,\n  provider: 'avisa',\n  canal: 'whatsapp',\n  entregue,\n  http_status_avisa: httpStatus\n});\n\nconst timBody = JSON.stringify({\n  numero: dadosMsg.numero,\n  nome: dadosMsg.nome,\n  area: dadosMsg.areaAtual,\n  estagio: 'atendimento',\n  ultimo_contato: new Date().toISOString()\n});\n\nreturn [{ json: { logBody, timBody, entregue } }];"
